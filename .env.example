# Shared secret between the UI container and the host helper.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
HELPER_SECRET=change_me_to_a_random_secret

# Flask session signing key for the UI.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change_me_to_a_random_secret

# Optional: helper audit log location (host helper service).
AUDIT_LOG=/opt/crowdsec-gui/helper/crowdsec-audit.log
